# OpenMux 配置示例

# 服务配置
server:
  port: 8080
  host: "0.0.0.0"
  timeout: 120s
  read_timeout: 60s
  write_timeout: 60s

# 认证配置
auth:
  enabled: false
  api_keys:
    - key: "sk-your-service-key-1"
      name: "client-1"
      rate_limit:
        rpm: 500
        tpm: 200000
        concurrent: 50
    - key: "sk-your-service-key-2"
      name: "client-2"
      rate_limit:
        rpm: 1000
        tpm: 500000
        concurrent: 100

# Provider 配置
providers:
  zhipu:
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    type: "openai"
    timeout: 60s
    retry:
      max_attempts: 3
      backoff: "exponential"
    rate_limit:
      rpm: 100
      tpm: 50000
      concurrent: 10
    api_keys:
      - "${ZHIPU_KEY_1}"
      - "${ZHIPU_KEY_2}"
    # load_balancer: # 可选，为 zhipu 单独配置密钥均衡策略
    #   strategy: "weighted_round_robin" # 默认为轮询
    #   health_check:
    #     enabled: true
    #     interval: 30s
    #     timeout: 5s
    #     unhealthy_threshold: 3
    #     healthy_threshold: 2

  aliyun:
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    type: "openai"
    timeout: 60s
    rate_limit:
      rpm: 200
      tpm: 100000
      concurrent: 20
    api_keys:
      - "${ALIYUN_KEY_1}"

  deepseek:
    base_url: "https://api.deepseek.com/v1"
    type: "openai"
    timeout: 60s
    rate_limit:
      rpm: 200
      tpm: 100000
      concurrent: 20
    api_keys:
      - "${DEEPSEEK_KEY_1}"



# 高级模型路由配置 (支持权重)
model_routes:
  large-model:
    description: "通用大模型"
    targets:
      - provider: deepseek
        model: deepseek-chat
        weight: 3
      - provider: zhipu
        model: glm-4-plus
        weight: 1
    strategy: weighted_round_robin

  # 同一模型的多云部署
  glm-4-flash:
    description: "GLM-4-Flash 多云部署"
    targets:
      - provider: zhipu
        model: glm-4-flash
        weight: 2
      - provider: aliyun
        model: glm-4-flash
        weight: 1
    strategy: weighted_round_robin





# 监控配置
monitoring:
  enabled: true
  metrics_path: "/metrics"
  log_level: "info"

# 缓存配置
cache:
  enabled: false
  ttl: 3600s
  max_size: 1000